NODE_ENV=development
PORT=4000
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000
# Temporary compatibility alias for existing web deployments.
NEXT_PUBLIC_API_BASE_URL=
CORS_ORIGINS=http://localhost:3000
TRUST_PROXY_HOPS=0
DEFAULT_TENANT_ID=11111111-1111-4111-8111-111111111111
# Shared secret used to authenticate browser client IPs forwarded by the web BFF.
BFF_SHARED_SECRET=

DATABASE_URL=postgresql://auto_iq:auto_iq_dev@localhost:5432/auto_iq
DATABASE_SSL=false
DATABASE_SSL_CA=
DATABASE_SSL_SERVER_NAME=
# TypeORM CLI migrations only require NODE_ENV, DATABASE_URL, and DATABASE_SSL.
REDIS_URL=redis://localhost:6379

CSRF_COOKIE_NAME=auto_iq_csrf
CSRF_HEADER_NAME=x-csrf-token
SESSION_COOKIE_NAME=auto_iq_session
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_SECURE=false
SESSION_SECRET=dev-auto-iq-session-secret-change-me
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=auto-iq-local
# Railway/Tigris aliases. In staging/production use the native names below;
# Railway bucket references resolve them automatically.
AWS_ENDPOINT_URL=
AWS_ENDPOINT_URL_S3=
AWS_DEFAULT_REGION=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
BUCKET_NAME=
AWS_S3_URL_STYLE=virtual
STORAGE_CONNECT_TIMEOUT_MS=10000
STORAGE_SOCKET_TIMEOUT_MS=30000
REQUEST_TIMEOUT_MS=10000
GLOBAL_RATE_LIMIT_WINDOW_SECONDS=60
GLOBAL_RATE_LIMIT_MAX=120
MAX_IMAGE_UPLOAD_BYTES=10485760
MAX_DOCUMENT_UPLOAD_BYTES=15728640
WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
MOBILE_RESET_URL=autoiq://reset-password
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PRESIGN_TTL_SECONDS=900
SWAGGER_ENABLED=true

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=local
OPENAPI_OUTPUT_PATH=
ENABLE_TEST_ERROR_ROUTE=false
DEBUG_TEST_ERROR_TOKEN=

NOTIFICATION_ACTIVE_CHANNELS=EMAIL,SMS
NOTIFICATION_MAX_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY_SECONDS=300
NOTIFICATION_REMINDER_INTERVAL_MS=300000
NOTIFICATION_CLAIM_LEASE_SECONDS=120
NOTIFICATION_EMAIL_PROVIDER=sandbox
NOTIFICATION_EMAIL_FROM=
NOTIFICATION_EMAIL_REPLY_TO=
RESEND_API_KEY=
SENDGRID_API_KEY=
SENDGRID_API_BASE_URL=https://api.sendgrid.com
SENDGRID_SENDER_EMAIL=
EMAIL_SENDER_EMAIL=
NOTIFICATION_SMS_PROVIDER=sandbox
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
GIKKO_API_KEY=
GIKKO_SMS_API_KEY=
GIKKO_BASE_URL=https://api.infobip.com
GIKKO_SMS_SEND_URL=
GIKKO_SENDER_NAME=
GIKKO_SMS_SENDER=
GIKKO_DELIVERY_REPORT_URL=
GIKKO_SMS_NOTIFY_URL=
GIKKO_SMS_AUTH_SCHEME=App
GIKKO_SMS_TIMEOUT_MS=10000
GIKKO_SMS_ENABLED=true
