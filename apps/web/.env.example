# API origin used by server components for /api/v1 requests.
# Canonical API origin. Optional /api/v1 suffixes are normalized away.
NEXT_PUBLIC_API_URL=http://localhost:4000
# Temporary compatibility alias; remove after existing deployments migrate.
NEXT_PUBLIC_API_BASE_URL=
WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
WEB_API_TIMEOUT_MS=10000
# Number of trusted web-edge proxies represented in X-Forwarded-For.
WEB_TRUSTED_PROXY_HOPS=1
# Must match the API BFF_SHARED_SECRET; provide through the secret manager.
BFF_SHARED_SECRET=

# Public storage origin used as the next/image remote pattern. Pin to your
# Tigris/MinIO/S3 hostname in production; leave unset only for local dev where
# the dev fallback (`https://**`) is acceptable.
STORAGE_PUBLIC_BASE_URL=

# Optional Sentry configuration for the web app (mirrors the API).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=local
SENTRY_ORG=
SENTRY_PROJECT=
# Build-time secret; inject from CI/deployment secret storage.
SENTRY_AUTH_TOKEN=
